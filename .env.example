# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── Instagram Graph API ───────────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token
INSTAGRAM_BUSINESS_ID=your_ig_business_account_id

# ── Telegram Bot (main 서버만 필요) ───────────────────────────────────────────
TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_OWNER_ID=123456789

# ── Worker 연결 (main 서버만 필요) ────────────────────────────────────────────
# Hetzner 사설망 IP 사용 (예: http://10.0.0.2:8000)
WORKER_URL=http://10.0.0.2:8000
WORKER_SECRET=your-random-secret-token

# ─────────────────────────────────────────────────────────────────────────────
# 서버별 필요 변수 요약:
#
# [worker 서버]
#   ANTHROPIC_API_KEY, CLOUDINARY_URL, WORKER_SECRET
#
# [main 서버]
#   INSTAGRAM_ACCESS_TOKEN, INSTAGRAM_BUSINESS_ID
#   CLOUDINARY_URL  (promo.py 용)
#   TELEGRAM_TOKEN, TELEGRAM_OWNER_ID
#   WORKER_URL, WORKER_SECRET
# ─────────────────────────────────────────────────────────────────────────────
